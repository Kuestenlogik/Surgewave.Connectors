<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/Kuestenlogik/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <!-- Surgewave core packages live on GitHub Packages (and, for stable
           releases, on nuget.org). The dotted pattern catches library packages
           (Kuestenlogik.Surgewave.Client etc.); the kebab patterns catch the
           tool executables (surgewave-broker, surgewave-control, ...). -->
      <package pattern="Kuestenlogik.Surgewave.*" />
      <package pattern="surgewave-*" />
      <package pattern="surgewave" />
    </packageSource>
  </packageSourceMapping>
</configuration>
