<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Lokales Hauptrepo als Sibling-Klon erwartet (..\Surgewave\artifacts\pkg).
         Hat Vorrang vor dem GitHub-Packages-Feed, sodass lokale dev-builds (Plugin-
         Discovery-Fix, Build-Tooling-Updates) ohne Publish-Cycle einsetzbar sind. -->
    <add key="surgewave-local" value="..\Surgewave\artifacts\pkg" />
    <add key="github" value="https://nuget.pkg.github.com/Kuestenlogik/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="surgewave-local">
      <!-- dotted: Library-Pakete; kebab: Executables wie surgewave-broker / surgewave-control,
           gepackt mit AssemblyName als PackageId. Beide Muster sind noetig, weil Runtime-
           und Testing-Pakete transitiv auf surgewave-broker verweisen. -->
      <package pattern="Kuestenlogik.Surgewave.*" />
      <package pattern="surgewave-*" />
      <package pattern="surgewave" />
    </packageSource>
    <packageSource key="github">
      <package pattern="Kuestenlogik.Surgewave.*" />
      <package pattern="surgewave-*" />
      <package pattern="surgewave" />
    </packageSource>
  </packageSourceMapping>
</configuration>
